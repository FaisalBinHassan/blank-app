<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Shared storage between the main app and keyboard extension -->
    <key>com.apple.security.application-groups</key>
    <array>
        <!-- CHANGE THIS to match AppConstants.appGroupID -->
        <string>group.com.yourdomain.keyboardai</string>
    </array>
</dict>
</plist>
